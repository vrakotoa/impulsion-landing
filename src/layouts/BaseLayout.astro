---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'vero-rakoto.com — Accompagnement solopreneures', description = 'ACCOMPAGNEMENT MARKETING ET COACHING POUR SOLOPRENEURES' } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap" rel="stylesheet" />
    <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
  </head>
  <body class="antialiased min-h-screen flex flex-col overflow-x-hidden text-stone-900 selection:bg-rose-100 selection:text-rose-500 bg-white">
    <slot />
  </body>
</html>
