---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const blogImages = [
  'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=600&q=80',
  'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600&q=80',
  'https://images.unsplash.com/photo-1505330622279-bf7d7fc918f4?w=600&q=80'
];
---

<BaseLayout title="Vero Rakotoarisoa — Transition de milieu de vie, vitalité et entrepreneuriat après 40 ans" description="J'accompagne celles et ceux qui, après 40 ans, veulent comprendre ce qui change, faire le tri dans leurs idées, et transformer une intuition confuse en action concrète.">
  <Header />

  <!-- Section 1 : Hero -->
  <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 px-6 overflow-hidden flex items-center" style="background: radial-gradient(at top left, rgba(245, 239, 228, 0.8), transparent 50%), radial-gradient(at bottom right, rgba(252, 238, 242, 0.8), transparent 50%)">
    <div class="mx-auto w-full relative z-10 flex flex-col text-center max-w-4xl">
      <div class="flex flex-col items-center w-full">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-stone-200 shadow-sm mb-8">
          <span class="flex h-2 w-2 rounded-full bg-rose-500 animate-pulse"></span>
          <span class="sm:hidden text-[11px] font-medium uppercase tracking-wider text-stone-500 leading-relaxed">Après 40 ans</span><span class="hidden sm:inline text-xs font-medium uppercase tracking-wider text-stone-500 leading-relaxed">Transition de vie - après 40 ans</span>
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl text-stone-900 tracking-tight mb-8 leading-[1.1] sm:leading-none font-normal" style="font-family: 'Newsreader', serif">
          Le milieu de la vie n'est pas une crise, <br class="hidden md:block">
          <span class="italic text-gold">c'est une renaissance.</span>
        </h1>
        <p class="text-lg sm:text-xl md:text-2xl tracking-tight max-w-xl mb-10 leading-relaxed text-stone-800 font-medium mx-auto text-center">
          Clarifiez votre direction
          <br>
          pour avancer autrement, sans repartir de zéro.
        </p>
        <a href="https://open.spotify.com/show/4vfVOsg14rdEVq35mCNTdz" target="_blank" rel="noopener" class="inline-flex px-10 py-5 text-white rounded-xl transition-all duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1 active:scale-95 items-center justify-center gap-2 group w-full sm:w-auto max-w-md mx-auto font-bold uppercase tracking-widest text-base bg-primary hover:bg-primary-dark shadow-primary/30">
          Écouter le podcast
          <iconify-icon icon="solar:headphones-round-bold" class="text-xl group-hover:scale-110 transition-transform"></iconify-icon>
        </a>
      </div>
    </div>
  </section>

  <!-- Section 2 : Approche -->
  <section class="py-24 px-6 bg-white border-b border-stone-200" id="approche">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div class="rounded-2xl overflow-hidden h-[500px] border border-stone-200 shadow-sm relative order-2 md:order-1">
        <img src="/images/Photo Vero printemps.jpg" alt="Vero Rakotoarisoa" class="absolute inset-0 w-full h-full object-cover">
      </div>
      <div class="order-1 md:order-2">
        <h2 class="text-3xl md:text-5xl tracking-tight text-stone-900 mb-6 font-normal" style="font-family: 'Newsreader', serif;">De l'introspection<br>à l'action</h2>
        <div class="space-y-6 text-stone-600 leading-relaxed text-base">
          <p>Quand on arrive au milieu de la vie, on sait que les questions ne sont jamais seulement professionnelles ou personnelles. Celles qui nous préoccupent touchent aussi bien le sens qu'on recherche au travail, le corps qui change, l'énergie, les relations, le rapport au temps, l'envie de contribuer autrement. Et quand on entreprend après un parcours salarié, cette bascule peut être encore plus forte : il faut apprendre à décider seul, garder son élan, trier ses idées et avancer sans s'épuiser.</p>
          <p><strong class="text-stone-900">Je suis Vero Rakotoarisoa.</strong></p>
          <p>Mon parcours relie deux mondes : l'accompagnement des transitions personnelles et le développement stratégique des activités indépendantes. J'aide à transformer le flou en décisions concrètes, à désencombrer ce qui disperse, et à retrouver une direction plus juste.</p>
          <blockquote class="pl-4 border-l-4 border-gold italic text-lg text-gold font-medium mt-6" style="font-family: 'Newsreader', serif;">« Faire moins, mais mieux. L'équilibre entre l'ambition personnelle et la sérénité professionnelle existe. »</blockquote>
        </div>
        <div class="mt-10">
          <a href="/contact" class="inline-flex px-10 py-5 text-white rounded-xl transition-all duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1 active:scale-95 items-center justify-center gap-2 group w-full sm:w-auto font-bold uppercase tracking-widest text-base bg-primary hover:bg-primary-dark shadow-primary/30">
            En discuter de vive voix
            <iconify-icon icon="solar:arrow-right-linear" class="text-xl group-hover:translate-x-0.5 transition-transform"></iconify-icon>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3 : 3 chemins -->
  <section class="py-24 px-6 bg-ivory border-y border-stone-200" id="chemins">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl tracking-tight text-stone-900 font-normal mb-4" style="font-family: 'Newsreader', serif;">3 chemins pour retrouver votre élan</h2>
        <p class="text-stone-600 max-w-2xl mx-auto leading-relaxed">Que vous cherchiez à vous réinventer, à consolider votre activité ou à clarifier vos envies.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Sommet : pleine largeur, immersive sombre -->
        <a href="/contact" class="md:col-span-2 group rounded-3xl overflow-hidden border border-stone-200 shadow-sm relative min-h-[400px] flex items-center bg-stone-900">
          <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1200&q=80" alt="Sommet montagne" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-60 transition-opacity duration-500">
          <div class="absolute inset-0 bg-gradient-to-r from-black/80 to-transparent"></div>
          <div class="relative z-10 p-10 md:p-16 text-white max-w-2xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/20 backdrop-blur-md border border-white/30 mb-6">
              <span class="flex h-2 w-2 rounded-full bg-rose-500 animate-pulse"></span>
              <span class="text-xs font-medium uppercase tracking-wider text-white">Événement</span>
            </div>
            <h3 class="text-4xl md:text-5xl font-normal mb-6 leading-tight tracking-tight" style="font-family: 'Newsreader', serif;">
              Le Sommet Virtuel de l'Audace & de la Vitalité après 40 ans
            </h3>
            <p class="text-white/80 text-lg mb-8 font-normal">
              Un rendez-vous inspirant avec une douzaine d'experts pour redéfinir la seconde moitié de sa vie avec puissance et liberté.
            </p>
            <span class="inline-flex px-8 py-4 bg-white text-stone-900 hover:bg-stone-100 rounded-xl transition-all shadow-sm font-bold uppercase tracking-widest text-sm items-center gap-2">
              Découvrir le sommet
              <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
            </span>
          </div>
        </a>

        <!-- Mastermind : CTA noir -->
        <a href="/mastermind-impulsion" class="bg-white rounded-3xl p-10 border border-stone-200 shadow-sm hover:border-rose-500/50 transition-colors flex flex-col justify-between group">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-rose-500/10 text-rose-500 mb-6">
              <span class="text-xs font-bold uppercase tracking-wider">Solopreneuriat</span>
            </div>
            <h3 class="text-2xl md:text-3xl font-normal text-stone-900 mb-4 leading-tight tracking-tight" style="font-family: 'Newsreader', serif;">
              Entreprendre au milieu de la vie
              <br>
              — Le Mastermind Impulsion
            </h3>
            <p class="text-stone-500 leading-relaxed mb-8 text-base">
              Un petit groupe d'avancement pour rompre la solitude, valider vos choix et passer à l'action sans vous épuiser.
            </p>
          </div>
          <span class="inline-flex px-8 py-4 bg-[#111111] hover:bg-[#222222] text-white rounded-xl transition-all shadow-xl hover:-translate-y-1 active:scale-95 font-bold uppercase tracking-widest text-sm justify-center text-center items-center gap-2">
            Rejoindre Impulsion
            <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
          </span>
        </a>

        <!-- Mini-programme audio : mockup compact, CTA noir -->
        <a href="/contact" class="bg-white rounded-3xl p-10 border border-stone-200 shadow-lg relative overflow-hidden group flex flex-col justify-between">
          <div class="absolute top-0 right-0 w-64 h-64 bg-stone-100 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=800&q=80" alt="Illustration désencombrement mental" class="absolute inset-0 w-full h-full object-cover opacity-10 group-hover:opacity-20 transition-opacity duration-500 z-0">
          <div class="relative z-10">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-stone-100 text-stone-600 mb-6">
              <iconify-icon icon="solar:headphones-round-bold" class="text-sm"></iconify-icon>
              <span class="text-xs font-bold uppercase tracking-wider">Mini-programme audio</span>
            </div>
            <h3 class="text-2xl md:text-3xl font-normal text-stone-900 mb-4 leading-tight tracking-tight" style="font-family: 'Newsreader', serif;">
              Désencombrement Mental
            </h3>
            <p class="text-stone-500 leading-relaxed mb-6 text-base">
              7 jours pour faire le tri dans votre vie, clarifier vos envies et faire de la place à votre nouvelle direction.
            </p>

            <div class="bg-stone-50 rounded-xl p-3 flex items-center gap-3 mb-8 border border-stone-200/50">
              <div class="w-8 h-8 rounded-full bg-stone-800 flex items-center justify-center shrink-0">
                <iconify-icon icon="solar:play-bold" class="text-white text-sm"></iconify-icon>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-end gap-[2px] h-5">
                  <div class="w-[2px] bg-stone-300 rounded-full" style="height: 40%"></div>
                  <div class="w-[2px] bg-stone-300 rounded-full" style="height: 70%"></div>
                  <div class="w-[2px] bg-stone-400 rounded-full" style="height: 90%"></div>
                  <div class="w-[2px] bg-stone-400 rounded-full" style="height: 55%"></div>
                  <div class="w-[2px] bg-stone-300 rounded-full" style="height: 75%"></div>
                  <div class="w-[2px] bg-stone-300 rounded-full" style="height: 35%"></div>
                  <div class="w-[2px] bg-stone-300 rounded-full" style="height: 60%"></div>
                  <div class="w-[2px] bg-stone-300 rounded-full" style="height: 80%"></div>
                </div>
                <div class="flex items-center justify-between mt-1">
                  <span class="text-xs text-stone-400">7 audio courts</span>
                  <span class="text-[10px] font-semibold uppercase tracking-wider text-primary bg-primary/10 px-2 py-0.5 rounded-full border border-primary/20">Simple & efficace</span>
                </div>
              </div>
            </div>
          </div>

          <div class="relative z-10 flex items-center justify-between gap-4">
            <span class="inline-flex flex-1 px-8 py-4 bg-[#111111] hover:bg-[#222222] text-white rounded-xl transition-all shadow-xl hover:-translate-y-1 active:scale-95 font-bold uppercase tracking-widest text-sm justify-center items-center gap-3 text-center">
              Accéder
              <span class="bg-white/20 px-2 py-1 rounded text-xs">27 €</span>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Section 4 : Newsletter -->
  <section class="py-24 px-6 bg-white border-y border-stone-200" id="newsletter">
    <div class="max-w-3xl mx-auto text-center">
      <iconify-icon icon="solar:letter-opened-bold" class="text-5xl text-gold mb-6"></iconify-icon>
      <h2 class="text-3xl md:text-5xl tracking-tight text-stone-900 mb-6 font-normal" style="font-family: 'Newsreader', serif;">La Chronique Après le Bruit</h2>
      <p class="text-stone-500 leading-relaxed mb-10 max-w-xl mx-auto text-lg">
        Des réflexions hebdomadaires sur l'art d'entreprendre avec justesse et de cultiver sa vitalité, directement dans votre boîte mail.
      </p>
      <a href="https://apreslebruit.substack.com" target="_blank" rel="noopener" class="inline-flex px-8 py-4 bg-gold hover:bg-[#A97823] text-white rounded-xl transition-all shadow-xl hover:-translate-y-1 active:scale-95 items-center justify-center gap-2 group font-bold uppercase tracking-wide text-base">
        Rejoindre sur Substack
        <iconify-icon icon="solar:arrow-right-linear" class="text-xl"></iconify-icon>
      </a>
    </div>
  </section>

  <!-- Section 5 : Blog -->
  <section class="py-24 px-6 bg-white" id="ressources">
    <div class="max-w-7xl mx-auto">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h2 class="text-3xl md:text-4xl tracking-tight text-stone-900 font-normal mb-4" style="font-family: 'Newsreader', serif;">Ressources & Réflexions</h2>
          <p class="text-lg text-stone-500">Derniers articles publiés.</p>
        </div>
        <a href="/ressources" class="hidden md:inline-flex items-center gap-2 text-primary hover:text-primary-dark font-semibold transition-colors">
          Voir tout
          <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {articles.map((article, i) => {
          const slug = article.id.replace('.md', '');
          const image = blogImages[i] || blogImages[0];
          const tagColor = i === 0 ? 'text-rose-500' : i === 1 ? 'text-gold' : 'text-primary';
          return (
            <a href={`/ressources/${slug}`} class="group">
              <div class="aspect-[4/3] rounded-2xl overflow-hidden mb-6 bg-stone-100">
                <img src={image} alt={article.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
              </div>
              <div class="flex gap-3 text-xs font-semibold uppercase tracking-wider mb-3">
                {article.data.tags.slice(0, 2).map((tag: string) => (
                  <span class={tagColor}>{tag}</span>
                ))}
              </div>
              <h3 class="text-xl font-normal text-stone-900 mb-3 group-hover:text-primary transition-colors tracking-tight" style="font-family: 'Newsreader', serif;">
                {article.data.title}
              </h3>
              <p class="text-stone-500 text-sm leading-relaxed">{article.data.description}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
