---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact — Vero Rakotoarisoa" description="Me contacter pour une question, une demande d'accompagnement ou un premier échange.">
  <Header />
  <main class="pt-32 pb-20 px-6 bg-ivory min-h-screen">
    <section class="max-w-5xl mx-auto">
      <h1 class="text-4xl md:text-6xl tracking-tight text-stone-900 mb-6 font-normal" style="font-family: 'Newsreader', serif;">Me contacter</h1>
      <p class="text-lg text-stone-600 leading-relaxed mb-10 max-w-2xl">Laissez-moi un message avec quelques éléments de contexte. Je vous répondrai directement par email.</p>

      <form action="https://formspree.io/f/xwvdddzd" method="POST" class="bg-white rounded-3xl border border-stone-200 shadow-sm p-6 sm:p-8 space-y-6 max-w-3xl">
        <input type="hidden" name="_subject" value="Nouveau message depuis vero-rakoto.com" />

        <div class="grid sm:grid-cols-2 gap-5">
          <label class="block"><span class="block text-sm font-semibold text-stone-700 mb-2">Prénom *</span><input name="prenom" autocomplete="given-name" required class="w-full rounded-xl border border-stone-200 bg-stone-50 px-4 py-3 outline-none focus:border-primary focus:bg-white" /></label>
          <label class="block"><span class="block text-sm font-semibold text-stone-700 mb-2">Nom *</span><input name="nom" autocomplete="family-name" required class="w-full rounded-xl border border-stone-200 bg-stone-50 px-4 py-3 outline-none focus:border-primary focus:bg-white" /></label>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <label class="block"><span class="block text-sm font-semibold text-stone-700 mb-2">Email *</span><input type="email" name="email" autocomplete="email" required class="w-full rounded-xl border border-stone-200 bg-stone-50 px-4 py-3 outline-none focus:border-primary focus:bg-white" /></label>
          <label class="block"><span class="block text-sm font-semibold text-stone-700 mb-2">Téléphone <span class="font-normal text-stone-400">optionnel</span></span><input type="tel" name="telephone" autocomplete="tel" class="w-full rounded-xl border border-stone-200 bg-stone-50 px-4 py-3 outline-none focus:border-primary focus:bg-white" /></label>
        </div>

        <label class="block"><span class="block text-sm font-semibold text-stone-700 mb-2">Message *</span><textarea name="message" rows="7" required class="w-full rounded-xl border border-stone-200 bg-stone-50 px-4 py-3 outline-none focus:border-primary focus:bg-white resize-y"></textarea></label>

        <label class="flex gap-3 text-sm text-stone-600 leading-relaxed"><input type="checkbox" name="rgpd" value="accepted" required class="mt-1 h-4 w-4 rounded border-stone-300" /><span>J'accepte que les informations transmises via ce formulaire soient utilisées uniquement pour répondre à ma demande.</span></label>

        <div class="flex flex-col sm:flex-row gap-4 sm:items-center">
          <button type="submit" class="inline-flex px-10 py-5 text-white rounded-xl transition-all duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1 active:scale-95 items-center justify-center gap-2 font-bold uppercase tracking-widest text-base bg-primary hover:bg-primary-dark shadow-primary/30">Envoyer le message</button>
          <a href="https://tidycal.com/verorakotoarisoa/30-minute-call" target="_blank" rel="noopener" class="inline-flex px-6 py-4 text-stone-900 bg-ivory hover:text-white rounded-xl transition-colors font-bold uppercase tracking-wider hover:bg-primary justify-center">Réserver un appel</a>
        </div>
      </form>
    </section>
  </main>
  <Footer />
</BaseLayout>
